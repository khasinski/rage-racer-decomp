+def _split_op(line: str) -> tuple[str, str]:
+    line = strip_comments(line)
+    if not line:
+        return "", ""
+    op, *rest = line.split(None, 1)
+    return op, rest[0] if rest else ""
+
+
+def _is_nop(line: str) -> bool:
+    return strip_comments(line) in ("nop", "#nop")
+
+
+def _is_non_instruction(line: str) -> bool:
+    stripped = strip_comments(line)
+    return stripped == "" or stripped.startswith(".") or stripped.endswith(":")
+
+
+def _previous_instruction_index(lines: List[str], start: int) -> int | None:
+    i = start
+    while i >= 0:
+        if not _is_non_instruction(lines[i]):
+            return i
+        i -= 1
+    return None
+
+
+def _is_return(line: str) -> bool:
+    op, rest = _split_op(line)
+    return op in return_mnemonics and rest in ("$31", "$ra")
+
+
+def _is_call(line: str) -> bool:
+    op, _ = _split_op(line)
+    return op in ("jal", "jalr")
+
+
+def _is_jump(line: str) -> bool:
+    op, _ = _split_op(line)
+    return op in ("j", "jr")
+
+
+def _is_branch(line: str) -> bool:
+    op, _ = _split_op(line)
+    return op in branch_mnemonics
+
+
+def _is_stack_adjust(line: str) -> bool:
+    op, rest = _split_op(line)
+    return op in ("addu", "addiu") and re.match(r"^\$sp,\$sp,", rest) is not None
+
+
+def _is_store(line: str) -> bool:
+    op, _ = _split_op(line)
+    return op in store_mnemonics
+
+
+def _is_store_without_at_expansion(line: str) -> bool:
+    return _is_store(line) and not uses_at(line)
+
+
+def _store_source_reg(line: str) -> str | None:
+    op, rest = _split_op(line)
+    if op not in store_mnemonics:
+        return None
+    parts = [part.strip() for part in rest.split(",", 1)]
+    if len(parts) != 2:
+        return None
+    return parts[0]
+
+
+def _load_dest_reg(line: str) -> str | None:
+    op, rest = _split_op(line)
+    if op not in load_mnemonics:
+        return None
+    parts = [part.strip() for part in rest.split(",", 1)]
+    if len(parts) != 2:
+        return None
+    return parts[0]
+
+
+def _is_la_tail(line: str) -> bool:
+    op, rest = _split_op(line)
+    return op in ("addiu", "ori") and "%lo(" in rest
+
+
+def _parse_la(line: str) -> tuple[str, str] | None:
+    op, rest = _split_op(line)
+    if op != "la":
+        return None
+    parts = [part.strip() for part in rest.split(",", 1)]
+    if len(parts) != 2:
+        return None
+    return parts[0], parts[1]
+
+
+def _parse_absolute_store(line: str) -> tuple[str, str, str] | None:
+    op, rest = _split_op(line)
+    if op not in store_mnemonics:
+        return None
+    parts = [part.strip() for part in rest.split(",", 1)]
+    if len(parts) != 2:
+        return None
+    reg, target = parts
+    if "(" in target or "%lo(" in target or is_number(target):
+        return None
+    return op, reg, target
+
+
+def _parse_indexed_symbol_store(line: str) -> tuple[str, str, str, str] | None:
+    op, rest = _split_op(line)
+    if op not in store_mnemonics:
+        return None
+    parts = [part.strip() for part in rest.split(",", 1)]
+    if len(parts) != 2:
+        return None
+    reg, target = parts
+    match = re.match(r"^([^()]+)\(([^)]+)\)$", target)
+    if match is None:
+        return None
+    symbol, base = match.group(1, 2)
+    if "%lo(" in symbol or is_number(symbol):
+        return None
+    return op, reg, symbol, base
+
+
+def _expand_la_into_delay(lines: List[str], control_predicate) -> List[str]:
+    res = lines[:]
+    i = 1
+    while i < len(res) - 1:
+        parsed = _parse_la(res[i - 1])
+        if control_predicate(res[i]) and _is_nop(res[i + 1]) and parsed is not None:
+            reg, symbol = parsed
+            res[i - 1] = f"lui\t{reg},%hi({symbol})"
+            res[i + 1] = f"addiu\t{reg},{reg},%lo({symbol})"
+            i += 2
+            continue
+        i += 1
+    return res
+
+
+def _expand_indexed_store_into_delay(
+    lines: List[str], control_predicate, skip_non_instruction: bool = False
+) -> List[str]:
+    res = lines[:]
+    i = 1
+    while i < len(res) - 1:
+        prev = _previous_instruction_index(res, i - 1) if skip_non_instruction else i - 1
+        parsed = _parse_indexed_symbol_store(res[prev]) if prev is not None else None
+        if control_predicate(res[i]) and _is_nop(res[i + 1]) and parsed is not None:
+            op, reg, symbol, base = parsed
+            res[prev : prev + 1] = [
+                f"lui\t$at,%hi({symbol})",
+                f"addu\t$at,$at,{base}",
+            ]
+            i += 1
+            res[i + 1] = f"{op}\t{reg},%lo({symbol})($at)"
+            i += 2
+            continue
+        i += 1
+    return res
+
+
+def _expand_store_into_delay(
+    lines: List[str], control_predicate, skip_non_instruction: bool = False
+) -> List[str]:
+    res = lines[:]
+    i = 1
+    while i < len(res) - 1:
+        prev = _previous_instruction_index(res, i - 1) if skip_non_instruction else i - 1
+        parsed = _parse_absolute_store(res[prev]) if prev is not None else None
+        if control_predicate(res[i]) and _is_nop(res[i + 1]) and parsed is not None:
+            op, reg, symbol = parsed
+            res[prev] = f"lui\t$at,%hi({symbol})"
+            res[i + 1] = f"{op}\t{reg},%lo({symbol})($at)"
+            i += 2
+            continue
+        i += 1
+    return res
+
+
+def _move_previous_into_delay(
+    lines: List[str],
+    control_predicate,
+    movable_predicate,
+    skip_non_instruction: bool = False,
+    remove_load_delay_nop: bool = False,
+) -> List[str]:
+    res = lines[:]
+    i = 1
+    while i < len(res) - 1:
+        prev = _previous_instruction_index(res, i - 1) if skip_non_instruction else i - 1
+        if (
+            control_predicate(res[i])
+            and _is_nop(res[i + 1])
+            and prev is not None
+            and movable_predicate(res[prev])
+        ):
+            movable = res[prev]
+            res[prev] = res[i]
+            res[i] = movable
+            del res[i + 1]
+            if remove_load_delay_nop:
+                nop = _previous_instruction_index(res, prev - 1)
+                load = _previous_instruction_index(res, nop - 1) if nop is not None else None
+                if (
+                    nop is not None
+                    and load is not None
+                    and _is_nop(res[nop])
+                    and _store_source_reg(movable) == _load_dest_reg(res[load])
+                ):
+                    del res[nop]
+            continue
+        i += 1
+    return res
+
