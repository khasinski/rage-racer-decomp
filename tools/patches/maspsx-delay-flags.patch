+        "sra\t$6,$6,16",
+        "sll\t$7,$7,16",
+        "sra\t$7,$7,16",
+    ]]
+    replacements = [[
+        "\tli\t$2,0x0000003c\t\t# 60",
+        "\tsw\t$2,16($sp)",
+        "\tsll\t$2,$3,9",
+        "\tsra\t$2,$2,16",
+        "\tsll\t$6,$6,16",
+        "\tsll\t$7,$7,16",
+        "\tli\t$4,0x00000013\t\t# 19",
+        "\tsra\t$6,$6,16",
+        "\tsra\t$7,$7,16",
+    ], [
+        "\tori\t$2,$zero,60",
+        "\tsw\t$2,16($sp)",
+        "\tsll\t$2,$3,9",
+        "\tsra\t$2,$2,16",
+        "\tsll\t$6,$6,16",
+        "\tsll\t$7,$7,16",
+        "\tori\t$4,$zero,19",
+        "\tsra\t$6,$6,16",
+        "\tsra\t$7,$7,16",
+    ]]
+    normalized = [strip_comments(line).strip() for line in res]
+    insn_indexes = [
+        i for i, line in enumerate(normalized) if line and not line.startswith(".") and not line.endswith(":")
+    ]
+    insns = [normalized[i] for i in insn_indexes]
+    for pattern, replacement in zip(patterns, replacements):
+        for i in range(len(insns) - len(pattern) + 1):
+            if insns[i : i + len(pattern)] == pattern:
+                start = insn_indexes[i]
+                end = insn_indexes[i + len(pattern) - 1] + 1
+                res[start:end] = replacement
